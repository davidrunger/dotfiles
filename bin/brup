#!/usr/bin/env zsh

# This `brup` script is named because it initially ran [br]ew [up]date and
# [br]ew [up]grade. Now it also updates other tools, like pnpm and Oh My Zsh. It
# also saves the printed output from the updates, in case that will be useful
# for future debugging of an issue that might have been caused by an upgrade, or
# in case there was some post-update tip I need to read (but didn't read when it
# was printed to the terminal).

set -eu # exit on any error, don't allow undefined variables

output_log_file=$HOME/code/dotfiles/personal/brew-updates/$(date -u +"%Y-%m-%dT%H:%M:%SZ").txt

mf "$output_log_file"

export ZSH=$HOME/.oh-my-zsh

update_homebrew() {
  brew update && brew upgrade
}

print_oh_my_zsh_sha() {
  git -C "$HOME/.oh-my-zsh" log --format=format:%H | head -n 1
}

update_oh_my_zsh() {
  sha_before=$(print_oh_my_zsh_sha)
  echo "Oh My Zsh SHA before: $sha_before"

  "$ZSH/tools/upgrade.sh"

  sha_after=$(print_oh_my_zsh_sha)
  echo "Oh My Zsh SHA after: $sha_after"

  "$ZSH/tools/changelog.sh" "$sha_after" "$sha_before"
}

perform_updates() {
  blue '=== pnpm ==='
  pnpm self-update
  echo

  blue '=== Homebrew ==='
  update_homebrew
  echo

  blue '=== Oh My Zsh ==='
  update_oh_my_zsh
}

perform_updates |& tee "$output_log_file"
