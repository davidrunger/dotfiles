#!/usr/bin/env bash

# Create an `.m3u8` playlist (named after the current directory) using all mp3
# files in the current directory.

set -euo pipefail # exit on any error, don't allow undefined variables, pipes don't swallow errors

playlist_name="$(basename "$PWD").m3u8"

{
  echo '#EXTM3U'

  find . -maxdepth 1 -type f -iname '*.mp3' -printf '%P\n' \
    | sort
} > "$playlist_name"

echo "Created playlist: $playlist_name"
